{
  "name": "hidden-shield",
  "version": "0.1.0",
  "private": true,
  "description": "HiddenShield desktop MVP scaffold powered by Vue, Vite and Tauri.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:stack": "node scripts/dev-stack.mjs",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "sync:verify": "node scripts/verify-mobile-sync-stub.mjs",
    "cloud:mock": "node scripts/cloud-sync-mock-server.mjs",
    "cloud:backend": "cargo run --manifest-path feedback-backend/Cargo.toml -- --bind-addr 127.0.0.1:43188 --db-path feedback-backend/cloud.sqlite",
    "cloud:contract": "node scripts/verify-cloud-sync-contract.mjs",
    "cloud:e2e": "node scripts/verify-cloud-sync-e2e.mjs",
    "cloud:ci": "node scripts/run-cloud-sync-ci.mjs",
    "mobile:doctor": "node scripts/mobile-doctor.mjs",
    "desktop:audio-rule": "node scripts/verify-audio-duration-rule.mjs",
    "desktop:audio-preflight": "node scripts/verify-audio-duration-preflight.mjs",
    "watermark:bench": "cargo run --manifest-path watermark-core/Cargo.toml --bin robustness_bench --",
    "watermark:matrix": "cargo run --manifest-path watermark-core/Cargo.toml --bin robustness_bench -- --audio-matrix"
  },
  "keywords": [
    "tauri",
    "vue",
    "ffmpeg",
    "copyright",
    "video"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "playwright": "^1.57.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vue-tsc": "^3.2.6"
  }
}
