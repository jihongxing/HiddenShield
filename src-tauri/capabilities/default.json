{
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-confirm",
    "updater:default"
  ]
}
